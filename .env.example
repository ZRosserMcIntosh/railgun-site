# Environment variables
# Copy this file to .env.local and fill in the values

# Site URL (used for sitemap, OG images, etc.)
NEXT_PUBLIC_SITE_URL=https://railgun.app

# Web App URL (for "Open Web App" links)
NEXT_PUBLIC_WEB_APP_URL=https://app.railgun.app

# GitHub repository URL
NEXT_PUBLIC_GITHUB_URL=https://github.com/ZRosserMcIntosh/railgun

# Analytics (optional)
# NEXT_PUBLIC_ANALYTICS_ID=

# Sentry (optional)
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
