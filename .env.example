# Environment variables
# Copy this file to .env.local and fill in the values

# Site URL (used for sitemap, OG images, etc.)
NEXT_PUBLIC_SITE_URL=https://railgun.app

# Web App URL (for "Open Web App" links)
NEXT_PUBLIC_WEB_APP_URL=https://app.railgun.app

# Railgun API
NEXT_PUBLIC_API_URL=https://railgun-api.fly.dev/api/v1

# Supabase Realtime (for real-time message delivery)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# GitHub repository URL
NEXT_PUBLIC_GITHUB_URL=https://github.com/ZRosserMcIntosh/railgun

# Analytics (optional)
# NEXT_PUBLIC_ANALYTICS_ID=

# Sentry (optional)
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
